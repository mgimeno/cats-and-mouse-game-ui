{
  "name": "cats-and-mouse-game-ui",
  "sideEffects": [
    "src/polyfills.ts"
  ],
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production && npm run pre-brotli:dist",
    "pre-gzip:dist": "node scripts/pre-gzip-dist.mjs",
    "pre-brotli:dist": "node scripts/pre-brotli-dist.mjs",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "lint": "ng lint && npm run lint:styles && npm run format:check",
    "lint:ts": "ng lint",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "lint:styles:fix": "stylelint \"src/**/*.scss\" --fix",
    "lint:fix": "ng lint --fix && npm run lint:styles:fix && npm run format:write",
    "format:check": "prettier . --check",
    "format:write": "prettier . --write",
    "validate": "npm run lint && npm run build",
    "check-all-updatable-dependencies": "npx npm-check-updates -u",
    "update-all-dependencies": "npx npm-check-updates -u && npm i -f"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 iOS versions",
    "last 2 ChromeAndroid versions",
    "Firefox ESR"
  ],
  "private": true,
  "dependencies": {
    "@angular/cdk": "^22.0.2",
    "@angular/common": "~22.0.4",
    "@angular/compiler": "~22.0.4",
    "@angular/core": "~22.0.4",
    "@angular/forms": "~22.0.4",
    "@angular/localize": "^22.0.4",
    "@angular/material": "^22.0.2",
    "@angular/platform-browser": "~22.0.4",
    "@angular/router": "~22.0.4",
    "@microsoft/signalr": "10.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "~22.0.4",
    "@angular/language-service": "^22.0.4",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "angular-eslint": "^22.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "stylelint": "^17.14.0",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "esbuild@0.28.1": true,
    "esbuild@0.27.7": true,
    "fsevents@2.3.3": true,
    "lmdb@3.5.4": true,
    "msgpackr-extract@3.0.4": true
  }
}
