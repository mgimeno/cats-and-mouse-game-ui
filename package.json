{
  "name": "cats-and-mouse-game-ui",
  "sideEffects": false,
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:production": "ng build --configuration production",
    "lint": "ng lint && npm run lint:styles && npm run format:check",
    "lint:ts": "ng lint",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "lint:styles:fix": "stylelint \"src/**/*.scss\" --fix",
    "lint:fix": "ng lint --fix && npm run lint:styles:fix && npm run format:write",
    "format:check": "prettier . --check",
    "format:write": "prettier . --write",
    "validate": "npm run lint && npm run build"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.11",
    "@angular/cdk": "^21.2.10",
    "@angular/common": "~21.2.11",
    "@angular/compiler": "~21.2.11",
    "@angular/core": "~21.2.11",
    "@angular/forms": "~21.2.11",
    "@angular/localize": "^21.2.11",
    "@angular/material": "^21.2.10",
    "@angular/platform-browser": "~21.2.11",
    "@angular/router": "~21.2.11",
    "@microsoft/signalr": "10.0.0",
    "lucide-angular": "^1.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "~21.2.11",
    "@angular/language-service": "^21.2.11",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "stylelint": "^17.11.0",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.2"
  }
}
